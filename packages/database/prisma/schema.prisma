generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionSource {
  WEB
  LINE
  RECURRING
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  lineUserId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  transactions Transaction[]
  categories   Category[]
  recurrings   Recurring[]
  budgets      Budget[]
  linkCodes    LinkCode[]
}

model Category {
  id        String          @id @default(cuid())
  name      String
  icon      String
  type      TransactionType
  userId    String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  recurrings   Recurring[]
  budgets      Budget[]

  @@index([userId])
  @@index([type])
}

model Transaction {
  id          String            @id @default(cuid())
  amount      Decimal           @db.Decimal(12, 2)
  type        TransactionType
  description String?
  source      TransactionSource @default(WEB)
  userId      String
  categoryId  String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([categoryId])
  @@index([userId, createdAt])
}

model Recurring {
  id          String          @id @default(cuid())
  amount      Decimal         @db.Decimal(12, 2)
  type        TransactionType
  description String?
  categoryId  String
  userId      String
  dayOfMonth  Int
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([active])
}

model Budget {
  id         String   @id @default(cuid())
  amount     Decimal  @db.Decimal(12, 2)
  categoryId String
  userId     String
  month      Int
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@unique([userId, categoryId, month, year])
  @@index([userId])
  @@index([userId, month, year])
}

model LinkCode {
  id        String    @id @default(cuid())
  code      String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
