# Postgres database — read by the postgres service on first boot to initialize the cluster.
POSTGRES_USER=postgres
POSTGRES_DB=finance_tracker
# Password for the postgres role above (leave blank, fill in a strong value).
POSTGRES_PASSWORD=

# Connection string used by the backend's Prisma client and by the migrator service.
# Host MUST be `postgres` (the compose service name). Replace <POSTGRES_PASSWORD> with the value above.
DATABASE_URL=postgresql://postgres:<POSTGRES_PASSWORD>@postgres:5432/finance_tracker?schema=public

# NestJS HTTP port (must match the port nginx upstream points to and the backend healthcheck).
PORT=3000
NODE_ENV=production

# JWT signing secret — long random string (e.g. `openssl rand -base64 48`).
JWT_SECRET=

# LINE Messaging API credentials (LINE Developers console).
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Anthropic Claude API key — used by the LINE auto-categorizer service.
ANTHROPIC_API_KEY=
