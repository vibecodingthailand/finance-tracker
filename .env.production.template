# ============================================================================
# Finance Tracker — Production environment
# copy ไฟล์นี้เป็น .env.production แล้วเติมค่าจริงทุก secret (อย่า commit)
# docker-compose จะอ่านไฟล์นี้ผ่าน env_file ของแต่ละ service
# ============================================================================

# ----------------------------------------------------------------------------
# PostgreSQL — ใช้โดย service `postgres` (image postgres:16-alpine อ่านเอง)
# ----------------------------------------------------------------------------
# ชื่อ user ของ DB (postgres image จะ create ให้ตอน init)
POSTGRES_USER=finance
# รหัสผ่านของ user — secret
POSTGRES_PASSWORD=
# ชื่อ database ที่ถูก create ตอน init
POSTGRES_DB=finance_tracker

# ----------------------------------------------------------------------------
# Database URL — ใช้โดย backend (Prisma client) และ migrator
# host ต้องเป็นชื่อ service ของ postgres ใน compose network (`postgres`)
# ต้อง match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB ด้านบน
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://finance:REPLACE_ME@postgres:5432/finance_tracker?schema=public

# ----------------------------------------------------------------------------
# Backend server (NestJS)
# ----------------------------------------------------------------------------
# port ที่ NestJS listen ภายใน container — ต้องตรงกับที่ nginx upstream ชี้ (3000)
PORT=3000
NODE_ENV=production

# CORS origins ที่อนุญาต (comma-separated) — ถ้า frontend กับ backend อยู่ domain เดียวกัน
# ผ่าน nginx reverse proxy สามารถเว้นว่างได้
CORS_ORIGINS=

# ----------------------------------------------------------------------------
# Auth / JWT — sign/verify access token
# ----------------------------------------------------------------------------
# secret สำหรับ JWT — ใช้ random string ยาว ๆ (เช่น `openssl rand -hex 32`)
JWT_SECRET=
# อายุ token (jsonwebtoken format เช่น "7d", "15m", "1h")
JWT_EXPIRES_IN=7d

# ----------------------------------------------------------------------------
# LINE Messaging API — LINE Developers Console → Messaging API channel
# ----------------------------------------------------------------------------
# ใช้ verify signature ของ webhook ที่ LineSignatureGuard — secret
LINE_CHANNEL_SECRET=
# ใช้ส่ง reply message กลับไปยัง LINE — secret
LINE_CHANNEL_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# Claude API (Anthropic) — ใช้ auto-categorize ข้อความจาก LINE + สร้าง insight
# ขอ key: https://console.anthropic.com/
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
