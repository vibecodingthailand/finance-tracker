{
  "name": "finance-tracker",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "frontend:dev": "pnpm --filter frontend dev",
    "backend:dev": "pnpm --filter backend start:dev",
    "db:generate": "pnpm --filter @finance-tracker/database prisma:generate",
    "db:migrate": "pnpm --filter @finance-tracker/database prisma:migrate",
    "db:seed": "pnpm --filter @finance-tracker/database db:seed",
    "db:reset": "pnpm --filter @finance-tracker/database prisma:reset",
    "db:studio": "pnpm --filter @finance-tracker/database prisma:studio",
    "bootstrap": "pnpm install && pnpm db:generate && pnpm build && pnpm db:migrate && pnpm db:seed"
  }
}
