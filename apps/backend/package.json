{
  "name": "@finance-tracker/backend",
  "version": "0.0.1",
  "private": true,
  "description": "Finance Tracker backend (NestJS 11)",
  "scripts": {
    "build": "pnpm --filter @finance-tracker/shared build && nest build",
    "start": "pnpm --filter @finance-tracker/shared build && nest start",
    "start:dev": "pnpm --filter @finance-tracker/shared build && nest start --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --filter @finance-tracker/shared build && jest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@finance-tracker/database": "workspace:*",
    "@finance-tracker/shared": "workspace:*",
    "@line/bot-sdk": "^11.0.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^30.3.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
