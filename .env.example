# ============================================================================
# Finance Tracker — ตัวอย่าง environment variables
# ใช้ร่วมกันทั้ง apps/backend และ packages/database (root-level single config)
# copy ไฟล์นี้เป็น .env แล้วเติมค่าจริง — .env ถูก ignore จาก git
# ============================================================================

# ----------------------------------------------------------------------------
# Database (ใช้ทั้ง backend และ packages/database/prisma)
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_tracker?schema=public"

# ----------------------------------------------------------------------------
# Backend server
# ----------------------------------------------------------------------------
# port ของ NestJS (default: 3000) — frontend เรียก http://localhost:$PORT/api
PORT=3000
NODE_ENV=development

# CORS: comma-separated origins ที่อนุญาตให้เรียก API ได้
# dev: ใส่ URL ของ Vite dev server; production: ปล่อยว่างได้ถ้า frontend กับ backend อยู่ domain เดียวกันผ่าน reverse proxy
CORS_ORIGINS=http://localhost:5173

# ----------------------------------------------------------------------------
# Auth / JWT
# ----------------------------------------------------------------------------
# ใช้ sign/verify JWT access token — ต้องตั้งค่า ห้ามใช้ default ใน production
JWT_SECRET="change-me-in-production"
# อายุ token ตาม jsonwebtoken format (เช่น "7d", "15m", "1h") — default: 7d
JWT_EXPIRES_IN=7d

# ----------------------------------------------------------------------------
# LINE Messaging API (LINE bot webhook + reply)
# ดูได้ที่ LINE Developers Console → Messaging API channel
# ----------------------------------------------------------------------------
# ใช้ verify signature ของ webhook request (ผ่าน LineSignatureGuard)
LINE_CHANNEL_SECRET=
# ใช้ส่ง reply message กลับไปยัง LINE (ผ่าน messagingApi.MessagingApiClient)
LINE_CHANNEL_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# Claude API (Anthropic) — ใช้จัดหมวดข้อความที่บันทึกจาก LINE อัตโนมัติ
# ขอ key ได้ที่ https://console.anthropic.com/
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
